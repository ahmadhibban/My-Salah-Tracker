<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_prayer_item_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginEnd="4dp"
    android:layout_marginStart="4dp">
    <ImageView android:id="@+id/card_border" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/widget_card_base" android:scaleType="fitXY" />
    <ImageView android:id="@+id/card_inner" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_margin="2dp" android:src="@drawable/widget_card_base" android:scaleType="fitXY" />
    <LinearLayout android:id="@+id/content_box" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical">
        <ImageView android:id="@+id/w_icon" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginBottom="4dp" android:scaleType="fitCenter" />
        <ImageView android:id="@+id/w_name_img" android:layout_width="wrap_content" android:layout_height="17dp" android:scaleType="fitCenter" />
    </LinearLayout>
</RelativeLayout>
